# Environment Variables for LinkedIn Automation Backend
# Copy this file to .env and fill in your API keys

# ===========================================
# GROQ API (RECOMMENDED - FREE & FAST)
# Get API key from: https://console.groq.com
# ===========================================
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# OPENAI API (OPTIONAL - PAID)
# Get API key from: https://platform.openai.com/api-keys
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# GOOGLE API (OPTIONAL)
# For Google Sheets logging and Drive integration
# ===========================================
GOOGLE_CLIENT_ID=597748647877-4ojprples4jtaq0fbq6udisb54ojke2l.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# ===========================================
# N8N WEBHOOK (OPTIONAL)
# For workflow automation
# ===========================================
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/linkedin

# Your existing Google Sheet
GOOGLE_SHEET_ID=12_ZnDRwhi-QJIrSGZeidOkGOcPnLqkPLaJCw7-HiQdg
PORT=3000
# Optional: Specific Google Drive folder for resumes
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here


# =============================================
# N8N CONFIGURATION (Future Use)
# =============================================
N8N_WEBHOOK_PROPOSAL_SUBMITTED=http://localhost:5678/webhook/proposal-submitted
N8N_WEBHOOK_RESUME_RECEIVED=http://localhost:5678/webhook/resume-received

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# LINKEDIN SESSION (OPTIONAL)
# For LinkedIn automation scripts
# ===========================================
LINKEDIN_SESSION_FILE=auth_state.json

# ===========================================
# DEBUG MODE
# ===========================================
DEBUG=false

